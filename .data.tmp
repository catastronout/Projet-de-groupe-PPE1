	function callFnct (parmas) { 

		var target = (typeof parmas.target === 'undefined') ? '' : parmas.target;

		if(target == 'sns_count') { // params 규격 {target: '실행구분', elementId: 'snsCmtCnt', dataJson: 'json 형태 입력 데이터'}
		// 기사 상단의 댓글count
			
			var dataJson = (typeof parmas.dataJson === 'undefined') ? '' : parmas.dataJson;
			var elementId = (typeof parmas.elementId === 'undefined') ? '' : parmas.elementId;

			if(dataJson != '' && elementId != ''){
				
				var _element = document.querySelector(elementId);
				if(_element){
					_element.value = dataJson;
				}
			}
		} else if (target == 'move_url') { // params 규격 {target: '실행구분', url: '이동 페이지 주소'}
		// 페이지 이동
		
			var url = (typeof parmas.url === 'undefined') ? '' : parmas.url;
			
			if(url != ''){
				location.href=url;
			}
		} else if (target == 'move_login') { // params 규격 {target: '실행구분', url: '이동 페이지 주소', params: '로그인 파라미터'}
		// 로그인 페이지 이동

			var url = (typeof parmas.url === 'undefined') ? '' : parmas.url;
			var params = (typeof parmas.params === 'undefined') ? '' : parmas.params;
			
			if(url != ''){
				location.href=url+encodeURIComponent(document.location.href)+params;
			}
		} else if (target == 'youtube_resize_iframe') { // params 규격 {target: '실행구분', elementClass: 'dom.php에서 youtube를 iframe으로 감싼 클래스명', height: '높이값', idx: 'youtube iframe 순번'}
		// 기사 내 youtube 플레이 셋팅

			var elementClass = (typeof parmas.elementClass === 'undefined') ? '' : parmas.elementClass;
			var height = (typeof parmas.height === 'undefined') ? '' : parmas.height;
			var idx = (typeof parmas.idx === 'undefined') ? '' : parseInt(parmas.idx);
			
			if(elementId != '' && height != ''){

				var _elementClassAll = document.querySelectorAll(elementClass);
				if(_elementClassAll){			
					if(typeof _elementClassAll[idx] !== 'undefined'){
						_elementClassAll[idx].style.height = height +'px';
					}
				}
			}
		} else if (target == 'move_scroll') { // params 규격 {target: '실행구분', x_pos: 0, y_pos: 0}
		// 페이지 스크롤 이동
		
			var x_pos = (typeof parmas.x_pos === 'undefined') ? '' : parseInt(parmas.x_pos);
			var y_pos = (typeof parmas.y_pos === 'undefined') ? '' : parseInt(parmas.y_pos);

			if (!isNaN(x_pos) && !isNaN(y_pos)) {
				window.scroll(x_pos, y_pos);
			}
		} else if (target == 'move_realname') { // params 규격 {target: '실행구분', check_url: '실명인증 url'}
			// 실명 인증 이동
				var check_url = (typeof parmas.check_url === 'undefined') ? '' : parmas.check_url;

				if(check_url != ''){

					var thisdomain = document.domain;
					if ( document.do